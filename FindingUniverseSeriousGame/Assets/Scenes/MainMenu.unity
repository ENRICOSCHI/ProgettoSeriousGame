    - target: {fileID: 3090756470198475442, guid: 54f593bad02ef6641ad8bbc1f13a8378, type: 3}
      propertyPath: categoryLists.Array.data[2].entries.Array.data[8].realName
      value: Space Road
      objectReference: {fileID: 0}
    - target: {fileID: 3090756470198475442, guid: 54f593bad02ef6641ad8bbc1f13a8378, type: 3}
      propertyPath: categoryLists.Array.data[2].entries.Array.data[9].realName
      value: Vortex
      objectReference: {fileID: 0}
    - target: {fileID: 3090756470198475442, guid: 54f593bad02ef6641ad8bbc1f13a8378, type: 3}
      propertyPath: categoryLists.Array.data[2].entries.Array.data[8].description
      value: "CLASSIFICAZIONE:\nJazz & Fusion\n\nDATI TRACCIA:\nAutore: Casiopea\nAlbum:
        Casiopea\nAnno: 1979\n\nPANORAMICA:\nLa versione definitiva per i fan non
        \xE8 quella in studio, ma quella dell'album live Mint Jams (1982). In quella
        registrazione, la band suona con una precisione talmente millimetrica che
        molti ascoltatori inizialmente pensarono fosse stata corretta o \"sequenziata\"
        al computer, mentre era tutta abilit\xE0 manuale pura.\n\nANOMALIA REGISTRATA:\nLa
        versione definitiva per i fan non \xE8 quella in studio, ma quella dell'album
        live Mint Jams (1982). In quella registrazione, la band suona con una precisione
        talmente millimetrica che molti ascoltatori inizialmente pensarono fosse
        stata corretta o \"sequenziata\" al computer, mentre era tutta abilit\xE0
        manuale pura."
      objectReference: {fileID: 0}
    - target: {fileID: 3090756470198475442, guid: 54f593bad02ef6641ad8bbc1f13a8378, type: 3}
      propertyPath: categoryLists.Array.data[2].entries.Array.data[9].description
      value: "CLASSIFICAZIONE:\nJazz Contemporaneo\n\nDATI TRACCIA:\nAutore: Kamasi
        Washington\nAlbum: Heaven and Earth\nAnno: 2018\n\nPANORAMICA:\nPubblicata
        nel 2018 all'interno dell'imponente doppio album Heaven and Earth, Vortex
        \xE8 un turbine di jazz spirituale moderno. Washington spinge l'acceleratore
        su una sezione di fiati monumentale e una ritmica martellante, creando un'atmosfera
        epica che sembra uscita da un colossal di fantascienza degli anni '60, ma
        con la potenza produttiva odierna.\n\nANOMALIA REGISTRATA:\nPer ottenere
        questo suono cos\xEC denso e \"caotico ma controllato\", Kamasi Washington
        ha registrato le sessioni con un'orchestra di 26 elementi e un coro di 20
        persone. Il titolo Vortex si riferisce proprio alla struttura della composizione,
        pensata per trascinare l'ascoltatore in un centro gravitazionale sonoro da
        cui \xE8 impossibile uscire."
      objectReference: {fileID: 0}
    - target: {fileID: 3090756470198475442, guid: 54f593bad02ef6641ad8bbc1f13a8378, type: 3}
      propertyPath: categoryLists.Array.data[2].entries.Array.data[8].isDiscovered
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 3090756470198475442, guid: 54f593bad02ef6641ad8bbc1f13a8378, type: 3}
